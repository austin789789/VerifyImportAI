{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "specops/test_requirement.schema.json",
  "title": "SpecOps Test Requirement",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "artifact_type",
    "schema_version",
    "status",
    "version",
    "statement",
    "source_requirement_ids",
    "acceptance_criteria",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "artifact_type": { "const": "test_requirement" },
    "schema_version": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "IN_REVIEW",
        "APPROVED",
        "REJECTED",
        "AUTO_FIX_IN_PROGRESS",
        "AUTO_FIXED_PENDING_REVIEW",
        "IMPACTED",
        "MANUAL_RECOVERY",
        "ARCHIVED"
      ]
    },
    "version": { "type": "string", "minLength": 1 },
    "statement": { "type": "string" },
    "source_requirement_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "audit_rationale_id": { "type": ["string", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
