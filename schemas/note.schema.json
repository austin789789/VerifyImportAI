{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "specops/note.schema.json",
  "title": "SpecOps Note",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "artifact_type",
    "schema_version",
    "status",
    "version",
    "title",
    "summary",
    "source_spec_ids",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "artifact_type": { "const": "note" },
    "schema_version": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "IN_REVIEW",
        "APPROVED",
        "REJECTED",
        "AUTO_FIX_IN_PROGRESS",
        "AUTO_FIXED_PENDING_REVIEW",
        "IMPACTED",
        "MANUAL_RECOVERY",
        "ARCHIVED"
      ]
    },
    "version": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "source_spec_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
