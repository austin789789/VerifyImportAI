{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "specops/trace_map.schema.json",
  "title": "SpecOps Trace Map Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "upstream_ids",
    "downstream_ids",
    "status",
    "version",
    "schema_version"
  ],
  "properties": {
    "artifact_id": { "type": "string", "minLength": 1 },
    "artifact_type": { "type": "string", "minLength": 1 },
    "upstream_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "downstream_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "schema_version": { "type": "string", "minLength": 1 },
    "last_review_id": { "type": ["string", "null"] },
    "audit_rationale_id": { "type": ["string", "null"] }
  }
}
