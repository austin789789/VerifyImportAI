{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "specops/requirement.schema.json",
  "title": "SpecOps Requirement",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "artifact_type",
    "schema_version",
    "status",
    "version",
    "title",
    "statement",
    "source_spec_ids",
    "source_note_ids",
    "trace",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "artifact_type": { "const": "requirement" },
    "schema_version": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "IN_REVIEW",
        "APPROVED",
        "REJECTED",
        "AUTO_FIX_IN_PROGRESS",
        "AUTO_FIXED_PENDING_REVIEW",
        "IMPACTED",
        "MANUAL_RECOVERY",
        "ARCHIVED"
      ]
    },
    "version": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "statement": { "type": "string" },
    "source_spec_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "source_note_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "compliance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classes", "asil", "cal"],
      "properties": {
        "classes": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "asil": {
          "type": ["string", "null"],
          "enum": ["QM", "A", "B", "C", "D", null]
        },
        "cal": {
          "type": ["string", "null"],
          "enum": ["QM", "1", "2", "3", "4", null]
        }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["graph_node_id", "downstream_test_requirement_ids"],
      "properties": {
        "graph_node_id": { "type": "string" },
        "downstream_test_requirement_ids": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "audit_rationale_id": { "type": ["string", "null"] },
    "variant_scope": {
      "type": "string",
      "enum": ["base", "overlay"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "APPROVED" } },
        "required": ["status"]
      },
      "then": {
        "required": ["audit_rationale_id"],
        "properties": {
          "audit_rationale_id": { "type": "string", "minLength": 1 }
        }
      }
    }
  ]
}
