        {
            "type": "equation_interline",
            "content": {
                "math_content": "D i s t _ {C a l c} = I N T e r N A L _ {T} R I P _ {R} A N G E _ {D} I S T _ {C} A L C",
                "math_type": "latex",
                "image_source": {
                    "path": "images/6e46118c975f15a9992759d204ce6e07c8c7a70ada56f2cba623e5679e2da9cc.jpg"
